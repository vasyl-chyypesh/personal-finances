{
  "permissions": {
    "allow": [
      "Bash(npm run *)", "Bash(npm test)", "Bash(npm start)",
      "Bash(npm install *)", "Bash(node --import tsx *)", "Bash(npx tsx *)",
      "Bash(npx tsc *)", "Bash(npx prettier *)", "Bash(npx eslint *)"
    ],
    "deny": [
      "mcp__sqlite-prod__write_query",
      "mcp__sqlite-prod__create_table"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format.sh" }
        ]
      }
    ]
  }
}