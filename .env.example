# Path to the SQLite database file (created automatically if missing)
DB_PATH=finance.db

# Port the API server listens on
PORT=3001

# Network interface the API binds to. Defaults to 127.0.0.1 (loopback only) so
# the unauthenticated API is not exposed to the LAN. Set to 0.0.0.0 to expose it
# on all interfaces — only do this behind authentication or a trusted proxy.
HOST=127.0.0.1

# AI chat (optional): turns chat messages into draft ledger entries using a
# local LLM served by Ollama (https://ollama.com). Install Ollama and run
# `ollama serve`; the model is pulled automatically on first chat use. Leave
# CHAT_MODEL empty to disable the feature. First use is slow while the model
# downloads (needs network once); afterwards it runs fully offline.
CHAT_MODEL=gemma4:12b-mlx
# Base URL of the Ollama daemon (default: http://127.0.0.1:11434).
# OLLAMA_HOST=http://127.0.0.1:11434
