# Path to the SQLite database file (created automatically if missing)
DB_PATH=finance.db

# Port the API server listens on
PORT=3001

# Network interface the API binds to. Defaults to 127.0.0.1 (loopback only) so
# the unauthenticated API is not exposed to the LAN. Set to 0.0.0.0 to expose it
# on all interfaces — only do this behind authentication or a trusted proxy.
HOST=127.0.0.1

# AI chat (optional): a local LLM that turns chat messages into draft ledger
# entries. The GGUF model is downloaded on first chat use into ./models from a
# Hugging Face `hf:<repo>:<quant>` URI. If the feature is never used, nothing is
# downloaded. First use is slow while the model downloads (needs network once).
CHAT_MODEL_URI=hf:unsloth/gemma-4-E4B-it-GGUF:Q4_K_M
# Optional override for where models are stored (default: ./models).
# CHAT_MODELS_DIR=./models
