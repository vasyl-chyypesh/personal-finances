# SQLite database file (auto-created if missing)
DB_PATH=finance.db

# API server port
PORT=3001

# API bind interface. Default 127.0.0.1 = loopback only; the API is
# unauthenticated, so use 0.0.0.0 only behind auth or a trusted proxy.
HOST=127.0.0.1

# AI chat (optional): drafts ledger entries from chat messages via a local
# Ollama LLM (https://ollama.com). Model is pulled on first use (needs network
# once, then offline). Leave empty to disable.
CHAT_MODEL=gemma4:e4b-mlx
# Ollama base URL (default: http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434

# Docker: the image fixes HOST/PORT/DB_PATH, and OLLAMA_HOST defaults to the
# bundled ollama service; set http://host.docker.internal:11434 to use a
# host-side Ollama instead.
