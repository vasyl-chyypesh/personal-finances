# Path to the SQLite database file (created automatically if missing)
DB_PATH=finance.db

# Port the API server listens on
PORT=3001

# Network interface the API binds to. Defaults to 127.0.0.1 (loopback only) so
# the unauthenticated API is not exposed to the LAN. Set to 0.0.0.0 to expose it
# on all interfaces — only do this behind authentication or a trusted proxy.
HOST=127.0.0.1
